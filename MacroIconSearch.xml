<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ UI_shared.xsd">
    <EditBox name="MacroIconSearchEditBoxTemplate" letters="40" historyLines="0" virtual="true" autoFocus="false">
        <Layers>
            <Layer level="BACKGROUND">
                <Texture setAllPoints="true">
                    <Color r="0" g="0" b="0" a="1"/>
                </Texture>
            </Layer>
            <Layer level="BORDER">
                <Texture>
                    <Anchors>
                        <Anchor point="TOPLEFT" x="1" y="-1"/>
                        <Anchor point="BOTTOMRIGHT" x="-1" y="1"/>
                    </Anchors>
                    <Color r="0.08" g="0.08" b="0.08" a="0.95"/>
                </Texture>
            </Layer>
        </Layers>
        <FontString inherits="SystemFont_Shadow_Med1"/>
        <Scripts>
            <OnLoad>
                self:SetTextInsets(5, 5, 0, 0)
            </OnLoad>
            <OnEscapePressed>self:ClearFocus()</OnEscapePressed>
        </Scripts>
    </EditBox>

    <Frame name="MacroIconSearchFrame" enableKeyboard="true" enableMouse="true" hidden="true">
        <!-- Reduced height to 140 since we removed a row -->
        <Size x="450" y="140"/>
        <Frames>
            <Frame parentKey="Border" inherits="DialogBorderDarkTemplate"/>
            
            <!-- ROW 1 -->
            <EditBox parentKey="SpellSearchBox" inherits="MacroIconSearchEditBoxTemplate">
                <Size x="180" y="22"/>
                <Anchors>
                    <Anchor point="TOPLEFT" x="25" y="-30"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString text="Spell Name:" inherits="SystemFont_Shadow_Med1" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="BOTTOMLEFT" relativePoint="TOPLEFT" x="0" y="5"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnTextChanged>if self:GetText() == "" then MacroIconSearch:ResetSearch() end</OnTextChanged>
                    <OnEnterPressed>MacroIconSearch:OnSpellSearchEnter(self)</OnEnterPressed>
                </Scripts>
            </EditBox>

            <EditBox parentKey="SpellIDBox" numeric="true" inherits="MacroIconSearchEditBoxTemplate">
                <Size x="100" y="22"/>
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.SpellSearchBox" relativePoint="RIGHT" x="40" y="0"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString text="Set Spell ID:" inherits="SystemFont_Shadow_Med1" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="BOTTOMLEFT" relativePoint="TOPLEFT" x="0" y="5"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnEnterPressed>MacroIconSearch:OnSpellIDEnter(self)</OnEnterPressed>
                </Scripts>
            </EditBox>

            <!-- ROW 2 -->
            <EditBox parentKey="IconIDBox" numeric="true" inherits="MacroIconSearchEditBoxTemplate">
                <Size x="100" y="22"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.SpellSearchBox" relativePoint="BOTTOMLEFT" x="0" y="-30"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString text="Set Icon ID:" inherits="SystemFont_Shadow_Med1" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="BOTTOMLEFT" relativePoint="TOPLEFT" x="0" y="5"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnEnterPressed>MacroIconSearch:OnIconIDEnter(self)</OnEnterPressed>
                </Scripts>
            </EditBox>

            <EditBox parentKey="ItemIDBox" numeric="true" inherits="MacroIconSearchEditBoxTemplate">
                <Size x="100" y="22"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.SpellIDBox" relativePoint="BOTTOMLEFT" x="0" y="-30"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString text="Set Item ID:" inherits="SystemFont_Shadow_Med1" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="BOTTOMLEFT" relativePoint="TOPLEFT" x="0" y="5"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnEnterPressed>MacroIconSearch:OnItemIDEnter(self)</OnEnterPressed>
                </Scripts>
            </EditBox>
        </Frames>
        <Layers>
            <Layer level="ARTWORK">
                <FontString text="Press Enter after typing a name or ID to search / set." inherits="GameFontHighlight" justifyH="CENTER">
                    <Anchors>
                        <!-- Increased Y offset to 20 to prevent clipping -->
                        <Anchor point="BOTTOM" x="0" y="20"/>
                    </Anchors>
                    <Color r="1" g="0.82" b="0" a="1"/>
                </FontString>
            </Layer>
        </Layers>
    </Frame>
</Ui>
